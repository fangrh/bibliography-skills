{
  "name": "bibliography-skills",
  "version": "1.1.0",
  "description": "Zotero-like bibliography extraction and management for Claude Code and Codex with abstract extraction, note generation, and citation tracking",
  "author": "fangrh",
  "license": "MIT",
  "repository": "fangrh/bibliography-skills-marketplace",
  "keywords": [
    "bibliography",
    "bibtex",
    "zotero",
    "academic",
    "latex",
    "citations",
    "doi",
    "arxiv",
    "abstract",
    "note-generation",
    "citation-tracking"
  ],
  "claude": {
    "commands": [
      "bib-extractor",
      "bib-note",
      "bib-preview",
      "bib-search",
      "bib-sync",
      "bib-track"
    ],
    "skills": [
      "bib-extractor"
    ],
    "dependencies": [
      "requests"
    ]
  },
  "install": {
    "commands": "commands/",
    "scripts": "scripts/",
    "dependencies": "requirements.txt"
  },
  "files": [
    {
      "source": "commands/bib-extractor.md",
      "destination": "~/.claude/commands/bib-extractor.md"
    },
    {
      "source": "commands/bib-note.md",
      "destination": "~/.claude/commands/bib-note.md"
    },
    {
      "source": "commands/bib-preview.md",
      "destination": "~/.claude/commands/bib-preview.md"
    },
    {
      "source": "commands/bib-search.md",
      "destination": "~/.claude/commands/bib-search.md"
    },
    {
      "source": "commands/bib-sync.md",
      "destination": "~/.claude/commands/bib-sync.md"
    },
    {
      "source": "commands/bib-track.md",
      "destination": "~/.claude/commands/bib-track.md"
    },
    {
      "source": "scripts/bib_extractor.py",
      "destination": "~/.claude/scripts/bib_extractor.py"
    },
    {
      "source": "scripts/bib_note_generator.py",
      "destination": "~/.claude/scripts/bib_note_generator.py"
    },
    {
      "source": "scripts/bib_sync.py",
      "destination": "~/.claude/scripts/bib_sync.py"
    },
    {
      "source": "scripts/bib_citation_tracker.py",
      "destination": "~/.claude/scripts/bib_citation_tracker.py"
    },
    {
      "source": "SKILL.md",
      "destination": "~/.claude/skills/bib-extractor.md"
    }
  ]
}

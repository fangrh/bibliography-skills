{
  "name": "bibliography-skills",
  "version": "1.0.1",
  "description": "Bibliography extraction and sentence-aware citation search for Claude Code and Codex",
  "author": "fangrh",
  "license": "MIT",
  "repository": "fangrh/bibliography-skills-marketplace",
  "keywords": [
    "bibliography",
    "bibtex",
    "zotero",
    "academic",
    "latex",
    "citations",
    "doi",
    "arxiv",
    "smart-search"
  ],
  "claude": {
    "commands": [
      "bib-extractor",
      "bib-searcher"
    ],
    "skills": [
      "bib-extractor"
    ],
    "dependencies": [
      "requests"
    ]
  },
  "install": {
    "commands": "commands/",
    "scripts": "scripts/",
    "dependencies": "requirements.txt"
  },
  "files": [
    {
      "source": "commands/bib-extractor.md",
      "destination": "~/.claude/commands/bib-extractor.md"
    },
    {
      "source": "commands/bib-searcher.md",
      "destination": "~/.claude/commands/bib-searcher.md"
    },
    {
      "source": "scripts/bib_extractor.py",
      "destination": "~/.claude/scripts/bib_extractor.py"
    },
    {
      "source": "scripts/bib_smart_search.py",
      "destination": "~/.claude/scripts/bib_smart_search.py"
    },
    {
      "source": "SKILL.md",
      "destination": "~/.claude/skills/bib-extractor.md"
    }
  ]
}

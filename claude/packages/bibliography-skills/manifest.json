{
  "name": "bibliography-skills",
  "version": "2.0.0",
  "description": "Bibliography extraction and sentence-aware citation search for Claude Code",
  "author": "fangrh",
  "license": "MIT",
  "repository": "https://github.com/fangrh/bibliography-skills",
  "keywords": [
    "bibliography",
    "bibtex",
    "zotero",
    "academic",
    "latex",
    "citations",
    "doi",
    "arxiv",
    "smart-search"
  ],
  "claude": {
    "commands": [
      "bib-extractor",
      "bib-searcher",
      "bib-sync",
      "bib-manage"
    ],
    "skills": [
      "bib-extractor",
      "bib-searcher",
      "bib-sync",
      "bib-manage"
    ],
    "dependencies": [
      "requests",
      "papis"
    ]
  },
  "install": {
    "commands": "claude/commands/",
    "scripts": "scripts/",
    "dependencies": "requirements.txt"
  },
  "files": [
    {
      "source": "claude/commands/bib-extractor.md",
      "destination": "~/.claude/commands/bib-extractor.md"
    },
    {
      "source": "claude/commands/bib-searcher.md",
      "destination": "~/.claude/commands/bib-searcher.md"
    },
    {
      "source": "claude/commands/bib-sync.md",
      "destination": "~/.claude/commands/bib-sync.md"
    },
    {
      "source": "claude/commands/bib-manage.md",
      "destination": "~/.claude/commands/bib-manage.md"
    },
    {
      "source": "scripts/bib_extractor.py",
      "destination": "~/.claude/scripts/bib_extractor.py"
    },
    {
      "source": "scripts/bib_smart_search.py",
      "destination": "~/.claude/scripts/bib_smart_search.py"
    },
    {
      "source": "scripts/bib_sync.py",
      "destination": "~/.claude/scripts/bib_sync.py"
    },
    {
      "source": "scripts/bib_manage.py",
      "destination": "~/.claude/scripts/bib_manage.py"
    },
    {
      "source": "scripts/bib_utils.py",
      "destination": "~/.claude/scripts/bib_utils.py"
    },
    {
      "source": "scripts/title_normalizer.py",
      "destination": "~/.claude/scripts/title_normalizer.py"
    }
  ]
}

{
  "name": "bibliography-skills",
  "version": "2.0.0",
  "description": "Bibliography extraction and sentence-aware citation search for Claude Code",
  "author": "fangrh",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fangrh/bibliography-skills"
  },
  "keywords": [
    "bibliography",
    "bibtex",
    "zotero",
    "academic",
    "latex",
    "citations",
    "doi",
    "arxiv",
    "smart-search"
  ],
  "claude": {
    "commands": [
      "bib-extractor",
      "bib-searcher",
      "bib-sync",
      "bib-manage"
    ],
    "dependencies": [
      "requests",
      "papis"
    ]
  },
  "install": {
    "commands_dir": "claude/commands",
    "scripts_dir": "scripts",
    "dependencies": "requirements.txt"
  }
}
